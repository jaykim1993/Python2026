# 그래프 꾸미기
# 글자 세로 회전
# rotation = 90
# 차트와 간격 넓히기
# labelpad = 15
# plt.grid(linestyle='--')   # 점선
plt.grid(linestyle=':')  # 더촘촘한점선
# plt.grid(linestyle='-.')   # 점-선 혼합
ax = sns.barplot(
    data=merged,
    x='지역',
    y="병원수",
    width=0.4,
    # color='skyblue',
    palette=['red', 'blue', 'green', 'orange'],
    hue='지역',
    legend=True
)

plt.title(
    "지역별 병원 수",
    fontsize=18,
    color='darkblue',
    pad=30
)
plt.xlabel(
    "지역",
    fontsize=14,
    fontweight='bold',
    color='purple'
)
plt.ylabel(
    "병원수",
    fontsize=14,
    fontweight='bold',
    color='green'
)
plt.xticks(
    fontsize=12,
    fontweight='bold',
    color='brown'
)
plt.yticks(
    fontsize=12,
    fontweight='bold',
    color='brown'
)
for i in range(len(merged['병원수'])):
    v = merged['병원수'][i]
    print(v)
    ax.text(
        i,
        v,
        int(v),
        ha='center',
        va='bottom'
    )
plt.tight_layout()
# 그래프 이미지 저장
plt.savefig("hospital_chart.png", dpi=300)

# 그래프 출력
plt.show()



