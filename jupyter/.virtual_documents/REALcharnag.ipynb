    "(단위: 건)",
    fontweight='bold',
    fontsize=12,
    rotation=0,
)
plt.gca().yaxis.set_label_coords(-0.05, 1.02)

plt.grid(axis='x', linestyle=':')
plt.grid(axis='y', linestyle=':')

plt.xticks(rotation=0)

plt.savefig('그래프10', transparent=True)  # 투명화 저장
